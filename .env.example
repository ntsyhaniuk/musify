# Copy to `.env` for local use. NEVER commit `.env` or real secrets.
# Before commits: leave `.env` unstaged; run `git checkout -- src/environments/` if `npm run env` dirtied them.

# Spotify (browser) — used by `npm run env` to write Angular environment files
CLIENT_ID=
REDIRECT_URI=http://127.0.0.1:4300/

# Last.fm — server-only (local proxy / Netlify). Never embed in the browser bundle.
# Used by `scripts/lastfm-dev-proxy.mjs` (`npm start`) and `netlify/functions/lastfm.ts`.
LASTFM_API_KEY=
